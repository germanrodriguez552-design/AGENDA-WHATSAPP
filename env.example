# Copia este archivo como ".env" y rellena tus valores reales.
# NUNCA subas el archivo ".env" real a GitHub.

# Datos de tu cuenta de Twilio (Console > Account Dashboard)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=tu_auth_token_aqui

# Número de WhatsApp del sandbox de Twilio (formato: whatsapp:+14155238886)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Tu API key de Anthropic (Claude) - se obtiene en console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Puerto del servidor (Render lo asigna automáticamente, puedes dejarlo)
PORT=3000
